local function getClosestPlayer()
    local closest, closestDist = nil, S.aimFOV
    local mp = UIS:GetMouseLocation()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isAlive(p) then
            local char = getChar(p)
            local part = char and char:FindFirstChild(S.hitPart) or getRoot(p)
            if char and part then
                local pos, vis = Camera:WorldToViewportPoint(part.Position)
                if vis then
                    local d = (Vector2.new(pos.X, pos.Y) - mp).Magnitude
                    if d < closestDist then
                        if not S.wallbang then
                            local params = RaycastParams.new()
                            params.FilterType = Enum.RaycastFilterType.Exclude
                            params.FilterDescendantsInstances = {LP.Character, Camera}
                            local dir = (part.Position - Camera.CFrame.Position).Unit * ((part.Position - Camera.CFrame.Position).Magnitude + 2)
                            local result = Workspace:Raycast(Camera.CFrame.Position, dir, params)
                            if result and result.Instance:IsDescendantOf(char) then
                                closest = p; closestDist = d
                            end
                        else
                            closest = p; closestDist = d
                        end
                    end
                end
            end
        end
    end
    return closest
end

