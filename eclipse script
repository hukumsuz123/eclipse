local espObjs = {}
local function cleanESP(p)
    if espObjs[p] then
        for _, v in pairs(espObjs[p]) do if typeof(v) == "Instance" then v:Destroy() elseif v.Remove then v:Remove() end end
        espObjs[p] = nil
    end
end

