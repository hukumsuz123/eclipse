local function createESP(p)
    if p == LP or espObjs[p] then return end
    local d = {}
    if Drawing then
        pcall(function()
            d.box = Drawing.new("Square"); d.box.Thickness = 1; d.box.Filled = false
            d.nameT = Drawing.new("Text"); d.nameT.Size = 16; d.nameT.Center = true; d.nameT.Outline = true; d.nameT.Color = Color3.new(1,1,1)
            d.hpT = Drawing.new("Text"); d.hpT.Size = 14; d.hpT.Center = true; d.hpT.Outline = true
            d.trc = Drawing.new("Line"); d.trc.Thickness = 1
            d.hpBarBg = Drawing.new("Line"); d.hpBarBg.Thickness = 3; d.hpBarBg.Color = Color3.new(0,0,0)
            d.hpBar = Drawing.new("Line"); d.hpBar.Thickness = 1
            d.bones = {}
            for i=1,15 do local l = Drawing.new("Line"); l.Thickness = 1; table.insert(d.bones, l) end
        end)
    end
    espObjs[p] = d
end

pcall(function()
    for _, p in ipairs(Players:GetPlayers()) do createESP(p) end
    Players.PlayerAdded:Connect(createESP)
    Players.PlayerRemoving:Connect(cleanESP)
end)

local bonePairsR15 = { {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"}, {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"}, {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"}, {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"}, {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"} }
local bonePairsR6 = { {"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"}, {"Torso", "Left Leg"}, {"Torso", "Right Leg"} }

addC("espLoop", RunService.RenderStepped:Connect(function()
    pcall(function()
        for p, d in pairs(espObjs) do
            if not p or not p.Parent then cleanESP(p); continue end
            local char = getChar(p)
            local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local pos, vis = Camera:WorldToViewportPoint(root.Position)
                if vis then
                    local head = char:FindFirstChild("Head")
                    local topPos = head and head.Position + Vector3.new(0, 0.5, 0) or root.Position + Vector3.new(0, 2, 0)
                    local bottomPos = root.Position - Vector3.new(0, 3, 0)
                    local top, _ = Camera:WorldToViewportPoint(topPos)
                    local bottom, _ = Camera:WorldToViewportPoint(bottomPos)
                    local bh = math.abs(top.Y - bottom.Y)
                    local bw = bh * 0.6

                    if S.espBoxes and d.box then
                        d.box.Position = Vector2.new(pos.X - bw/2, pos.Y - bh/2); d.box.Size = Vector2.new(bw, bh)
                        d.box.Color = S.espColor; d.box.Visible = true
                    elseif d.box then d.box.Visible = false end

                    if S.espNames and d.nameT then
                        local txt = p.DisplayName
                        if S.espDistance then txt = txt .. " [" .. math.floor((LP.Character and LP.Character.PrimaryPart and (root.Position - LP.Character.PrimaryPart.Position).Magnitude) or 0) .. "m]" end
                        d.nameT.Text = txt; d.nameT.Position = Vector2.new(pos.X, pos.Y - bh/2 - 16); d.nameT.Visible = true
                    elseif d.nameT then d.nameT.Visible = false end

                    if S.espHealth and d.hpT then
                        local hpPct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        d.hpT.Text = math.floor(hum.Health); d.hpT.Position = Vector2.new(pos.X, pos.Y + bh/2 + 3)
                        d.hpT.Color = Color3.fromRGB(255 * (1 - hpPct), 255 * hpPct, 0); d.hpT.Visible = true
                        local barX = pos.X - bw/2 - 5
                        d.hpBarBg.From = Vector2.new(barX, pos.Y - bh/2); d.hpBarBg.To = Vector2.new(barX, pos.Y + bh/2); d.hpBarBg.Visible = true
                        d.hpBar.From = Vector2.new(barX, pos.Y + bh/2); d.hpBar.To = Vector2.new(barX, pos.Y + bh/2 - (bh * hpPct))
                        d.hpBar.Color = Color3.fromRGB(255 * (1 - hpPct), 255 * hpPct, 0); d.hpBar.Visible = true
                    elseif d.hpT then
                        d.hpT.Visible = false; d.hpBarBg.Visible = false; d.hpBar.Visible = false
                    end

                    if S.espTracers and d.trc then
                        local orig = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        if S.espTracerOrigin == "Center" then orig = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
                        elseif S.espTracerOrigin == "Mouse" then orig = UIS:GetMouseLocation() end
                        d.trc.From = orig; d.trc.To = Vector2.new(pos.X, pos.Y + bh/2)
                        d.trc.Color = S.espColor
                        d.trc.Thickness = S.espTracerThick
                        d.trc.Transparency = S.espTracerTrans
                        d.trc.Visible = true
                    elseif d.trc then d.trc.Visible = false end

                    if S.espSkeletons and d.bones then
                        local isR15 = hum.RigType == Enum.HumanoidRigType.R15
                        local pairs = isR15 and bonePairsR15 or bonePairsR6
                        for i, b in ipairs(d.bones) do
                            if pairs[i] then
                                local p1 = char:FindFirstChild(pairs[i][1])
                                local p2 = char:FindFirstChild(pairs[i][2])
                                if p1 and p2 then
                                    local pos1, v1 = Camera:WorldToViewportPoint(p1.Position)
                                    local pos2, v2 = Camera:WorldToViewportPoint(p2.Position)
                                    if v1 and v2 then
                                        b.From = Vector2.new(pos1.X, pos1.Y); b.To = Vector2.new(pos2.X, pos2.Y)
                                        b.Color = S.espColor; b.Visible = true
                                    else b.Visible = false end
                                else b.Visible = false end
                            else b.Visible = false end
                        end
                    elseif d.bones then for _,b in ipairs(d.bones) do b.Visible = false end end
                    
                    if S.espChams then
                        local isVis = false
                        local params = RaycastParams.new()
                        params.FilterType = Enum.RaycastFilterType.Exclude
                        params.FilterDescendantsInstances = {LP.Character, Camera}
                        local res = Workspace:Raycast(Camera.CFrame.Position, (root.Position - Camera.CFrame.Position).Unit * ((root.Position - Camera.CFrame.Position).Magnitude + 2), params)
                        if res and res.Instance:IsDescendantOf(char) then isVis = true end
                        
                        if not char:FindFirstChild("_eclCham") then
                            local hl = Instance.new("Highlight")
                            hl.Name = "_eclCham"; hl.FillColor = isVis and S.espChamVisColor or S.espColor; hl.OutlineColor = Color3.new(1,1,1)
                            hl.FillTransparency = 0.5; hl.OutlineTransparency = 0; hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                            hl.Parent = char
                        else
                            char._eclCham.FillColor = isVis and S.espChamVisColor or S.espColor
                        end
                    else
                        if char:FindFirstChild("_eclCham") then char._eclCham:Destroy() end
                    end
                else
                    if d.box then d.box.Visible = false; d.nameT.Visible = false; d.hpT.Visible = false; d.hpBarBg.Visible = false; d.hpBar.Visible = false; d.trc.Visible = false end
                    if d.bones then for _,b in ipairs(d.bones) do b.Visible = false end end
